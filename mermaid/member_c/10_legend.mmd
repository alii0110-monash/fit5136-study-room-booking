flowchart TB
    subgraph LEGEND["Legend & Color Codes"]
        direction TB
        L1["
==========================================
MSSRB - Legend & Style Guide
==========================================
        "]
        L2["Green (#90EE90)
Success messages & Start screen
Example: [SUCCESS] Registration successful"]
        L3["Red/Pink (#FFB6C1)
Errors, Warnings, Admin menu
Example: [ERROR] Invalid credentials"]
        L4["Blue (#87CEEB)
Student screens, Information
Example: Account Details screen"]
        L5["Yellow (#FFE4B5)
Confirmation prompts
Example: Confirm checkout? (Y/N)"]
        L6["Gray (#F0F0F0)
Input fields, Data tables
Example: Enter Room ID: _"]
    end

    subgraph NAV["Navigation & Input"]
        direction TB
        N1["
==========================================
Navigation Guide
==========================================
        "]
        N2["Arrow Labels show user choices:

Menu Navigation:
  1, 2, 3, 4 - Select menu options
  0 - Go back / Return to previous menu

Confirmation:
  Y - Yes / Confirm
  N - No / Cancel

Input:
  Enter - Submit input
  _ (underscore) - Input cursor position
        "]
    end

    subgraph PRINCIPLES["Usability Principles (Ben Shneiderman)"]
        direction TB
        P1["
==========================================
Usability Principles
==========================================
        "]
        P2["P1: Offer Informative Feedback
Every action should produce feedback.
Green = success, Red = error,
Yellow = confirmation needed."]
        P3["P2: Reduce Short-term Memory Load
Keep navigation simple and clear.
Use consistent menus and clear labels."]
        P4["P3: Permit Reversible Actions
Prevent accidental actions with
confirmation dialogs (Y/N)."]
    end

    style LEGEND fill:#F0F0F0,stroke:#808080,stroke-width:2px
    style L2 fill:#90EE90,stroke:#228B22
    style L3 fill:#FFB6C1,stroke:#DC143C
    style L4 fill:#87CEEB,stroke:#4169E1
    style L5 fill:#FFE4B5,stroke:#DAA520
    style L6 fill:#D3D3D3,stroke:#808080
    style NAV fill:#F0F0F0,stroke:#808080
    style PRINCIPLES fill:#E6E6FA,stroke:#9370DB
