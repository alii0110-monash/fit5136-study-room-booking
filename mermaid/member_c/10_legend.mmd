flowchart TB
    subgraph LEGEND["Legend & Color Codes"]
        direction TB
        L1["
==========================================
MSSRB - Legend & Color Guide
==========================================
        "]
        L2["Green: Success messages & Start screen"]
        L3["Red/Pink: Errors, Warnings, Admin menu"]
        L4["Blue: Student screens, Information"]
        L5["Yellow: Confirmation prompts"]
        L6["Gray: Input fields, Data tables"]
    end

    subgraph NAV["Navigation & Input"]
        direction TB
        N1["
==========================================
Navigation Guide
==========================================
        "]
        N2["Arrow Labels show user choices:
1, 2, 0 - Menu options
Y, N - Confirmation
Enter - Proceed with input"]
    end

    subgraph PRINCIPLES["Usability Principles (Ben Shneiderman)"]
        direction TB
        P1["
==========================================
Usability Principles
==========================================
        "]
        P2["P1: Offer informative feedback
Green success, Red errors,
Yellow confirmations"]
        P3["P2: Reduce short-term memory load
Clear labels, simple navigation"]
        P4["P3: Permit reversible actions
Y/N confirmations prevent errors"]
    end

    style LEGEND fill:#F0F0F0,stroke:#808080,stroke-width:2px
    style L2 fill:#90EE90,stroke:#228B22
    style L3 fill:#FFB6C1,stroke:#DC143C
    style L4 fill:#87CEEB,stroke:#4169E1
    style L5 fill:#FFE4B5,stroke:#DAA520
    style L6 fill:#D3D3D3,stroke:#808080
    style NAV fill:#F0F0F0,stroke:#808080
    style PRINCIPLES fill:#E6E6FA,stroke:#9370DB
